{
  "datasets": [
    {
      "name": "region_sales",
      "displayName": "Regional Sales",
      "queryLines": [
        "SELECT region, year_month, total_revenue, order_count, avg_order_value, unique_customers\n",
        "FROM workspace.lakeflow_lab_dev.gold_sales_by_region\n",
        "ORDER BY region, year_month"
      ]
    },
    {
      "name": "top_products",
      "displayName": "Top Products",
      "queryLines": [
        "SELECT product, category, total_revenue, total_units_sold, order_count, avg_unit_price\n",
        "FROM workspace.lakeflow_lab_dev.gold_top_products\n",
        "ORDER BY total_revenue DESC"
      ]
    },
    {
      "name": "summary_metrics",
      "displayName": "Summary Metrics",
      "queryLines": [
        "SELECT\n",
        "  ROUND(SUM(total_revenue), 2) AS total_revenue,\n",
        "  SUM(order_count) AS total_orders,\n",
        "  ROUND(AVG(avg_order_value), 2) AS avg_order_value\n",
        "FROM workspace.lakeflow_lab_dev.gold_sales_by_region"
      ]
    }
  ],
  "pages": [
    {
      "name": "sales_overview",
      "displayName": "Sales Overview",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": [
                "# Sales Dashboard\n",
                "Key metrics from the Lakeflow Lab medallion pipeline"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 12,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "total_revenue_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "summary_metrics",
                  "fields": [
                    {
                      "name": "sum(total_revenue)",
                      "expression": "SUM(`total_revenue`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "showTitle": true,
                "title": "Total Revenue"
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "sum(total_revenue)"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 4,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "total_orders_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "summary_metrics",
                  "fields": [
                    {
                      "name": "sum(total_orders)",
                      "expression": "SUM(`total_orders`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "showTitle": true,
                "title": "Total Orders"
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "sum(total_orders)"
                }
              }
            }
          },
          "position": {
            "x": 4,
            "y": 1,
            "width": 4,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "avg_order_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "summary_metrics",
                  "fields": [
                    {
                      "name": "sum(avg_order_value)",
                      "expression": "SUM(`avg_order_value`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "showTitle": true,
                "title": "Average Order Value"
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "sum(avg_order_value)"
                }
              }
            }
          },
          "position": {
            "x": 8,
            "y": 1,
            "width": 4,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "revenue_by_region",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "region_sales",
                  "fields": [
                    {
                      "name": "region",
                      "expression": "`region`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "SUM(`total_revenue`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "region",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Region"
                },
                "y": {
                  "fieldName": "total_revenue",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "Total Revenue"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 3,
            "width": 6,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "revenue_trend",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "region_sales",
                  "fields": [
                    {
                      "name": "year_month",
                      "expression": "`year_month`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "SUM(`total_revenue`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "year_month",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Month"
                },
                "y": {
                  "fieldName": "total_revenue",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "Revenue"
                }
              }
            }
          },
          "position": {
            "x": 6,
            "y": 3,
            "width": 6,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "top_products_table",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "top_products",
                  "fields": [
                    {
                      "name": "product",
                      "expression": "`product`"
                    },
                    {
                      "name": "category",
                      "expression": "`category`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    },
                    {
                      "name": "total_units_sold",
                      "expression": "`total_units_sold`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "showTitle": true,
                "title": "Top Products"
              },
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {
                    "fieldName": "product"
                  },
                  {
                    "fieldName": "category"
                  },
                  {
                    "fieldName": "total_revenue"
                  },
                  {
                    "fieldName": "total_units_sold"
                  }
                ]
              }
            }
          },
          "position": {
            "x": 0,
            "y": 7,
            "width": 12,
            "height": 6
          }
        }
      ],
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1"
    }
  ],
  "uiSettings": {
    "theme": {
      "widgetHeaderAlignment": "ALIGNMENT_UNSPECIFIED"
    },
    "applyModeEnabled": false
  }
}
